{
  "extends": "@gingacodemonkey/config/bundler/no-dom/library",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "incremental": false,
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": [
    "eslint.config.ts",
    "eslint.config.style.ts",
    "./rules/**/*.ts",
    "index.ts",
    "./tests/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
