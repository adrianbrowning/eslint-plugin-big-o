{
  "name": "eslint-plugin-big-o",
  "version": "1.1.0",
  "description": "ESLint rules for detecting algorithmic complexity issues (Big-O)",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "big-o",
    "complexity",
    "performance"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianbrowning/eslint-plugin-big-o.git"
  },
  "bugs": {
    "url": "https://github.com/adrianbrowning/eslint-plugin-big-o/issues"
  },
  "homepage": "https://github.com/adrianbrowning/eslint-plugin-big-o#readme",
  "author": "Adrian Elton-Browning",
  "license": "ISC",
  "type": "module",
  "zshy": {
    "exports": {
      ".": "./index.ts"
    },
    "cjs": false
  },
  "scripts": {
    "build": "zshy",
    "test": "vitest run",
    "lint:ts": "tsc --noEmit",
    "lint:esl": "eslint --config eslint.config.ts . --cache --max-warnings=0",
    "lint:s": "eslint --config eslint.config.style.ts . --cache --max-warnings=0",
    "lint:fix": "pnpm lint:s --fix",
    "lint:knip": "knip",
    "lint:jscpd": "jscpd .",
    "lint": "pnpm lint:ts && pnpm lint:fix",
    "lint:e18e": "pnpm dlx @e18e/cli analyze"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "@commitlint/cli": "20.0.0",
    "@commitlint/config-conventional": "20.0.0",
    "@gingacodemonkey/config": "^0.0.35",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^24.13.2",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript-eslint/rule-tester": "^8.61.1",
    "@typescript-eslint/utils": "^8.61.1",
    "eslint": "^9.39.4",
    "husky": "9.0.6",
    "jscpd": "^4.2.5",
    "knip": "5.70.1",
    "lint-staged": "15.2.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zshy": "latest"
  },
  "pnpm": {
    "minimumReleaseAge": 4320
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
